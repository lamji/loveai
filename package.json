{
  "name": "loveai",
  "version": "1.0.0",
  "description": "LoveAi — futuristic multi-agent desktop console for Claude Code",
  "author": "Anthropic",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.loveai.console",
    "productName": "LoveAi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/**",
      "node_modules/@lydell/**",
      "**/*.exe",
      "**/*.node"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LoveAi",
      "runAfterFinish": false
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "shiki": "^4.3.1"
  }
}

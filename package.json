{
  "name": "loveai",
  "version": "1.0.3",
  "description": "LoveAi — futuristic multi-agent desktop console for Claude Code",
  "author": "Anthropic",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.loveai.console",
    "productName": "LoveAi",
    "protocols": [
      {
        "name": "LoveAi",
        "schemes": [
          "loveai"
        ]
      }
    ],
    "icon": "build/icon.png",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "auth.js",
      "config.js",
      "vectors.js",
      "vectors-worker.js",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/**",
      "node_modules/@lydell/**",
      "node_modules/web-tree-sitter/**",
      "node_modules/tree-sitter-wasms/**",
      "node_modules/onnxruntime-node/**",
      "**/*.exe",
      "**/*.node",
      "**/*.dll",
      "**/*.wasm"
    ],
    "extraResources": [
      {
        "from": "local_cache",
        "to": "local_cache"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LoveAi",
      "runAfterFinish": false
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@supabase/supabase-js": "^2.109.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "fastembed": "^2.1.0",
    "shiki": "^4.3.1",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.25.10",
    "ws": "^8.21.1"
  }
}
